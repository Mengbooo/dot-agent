# ============================================
# AI Agent 配置环境变量模板
# ============================================
# 复制此文件为 .env 并填入你的真实密钥
# cp .env.template .env

# ========== Hermes ==========
# MiniMax API (Hermes 主模型)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_CN_API_KEY=your_minimax_cn_api_key_here

# OpenRouter (备选模型路由)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ========== Claude Code ==========
# MiniMax API (与 Hermes 共用)
ANTHROPIC_AUTH_TOKEN=your_anthropic_auth_token_here
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# Claude Code 可用模型
ANTHROPIC_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_OPUS_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M2.7

# ========== OpenClaw ==========
OPENCLAW_TOKEN=your_openclaw_token_here
OPENCLAW_WORKSPACE=~/.openclaw/workspace
